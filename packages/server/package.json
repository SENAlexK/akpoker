{
  "name": "@akpoker/server",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "scripts": {
    "build": "tsc -b && pnpm run copy:assets",
    "copy:assets": "mkdir -p dist/db/migrations && cp src/db/migrations/*.sql dist/db/migrations/",
    "dev": "tsx watch src/index.ts",
    "start": "node dist/index.js",
    "test": "vitest run",
    "db:migrate": "tsx src/db/migrate.ts",
    "admin": "tsx src/admin/cli.ts",
    "clean": "rm -rf dist *.tsbuildinfo"
  },
  "dependencies": {
    "@akpoker/engine": "workspace:*",
    "@akpoker/shared": "workspace:*",
    "@fastify/cookie": "^11.0.2",
    "@fastify/cors": "^10.0.2",
    "@fastify/helmet": "^13.0.1",
    "@fastify/multipart": "^9.0.3",
    "@fastify/rate-limit": "^10.2.2",
    "@fastify/static": "^8.0.4",
    "@paralleldrive/cuid2": "^2.2.2",
    "argon2": "^0.41.1",
    "better-sqlite3": "^11.7.0",
    "drizzle-orm": "^0.38.3",
    "fastify": "^5.8.5",
    "jdenticon": "^3.3.0",
    "jose": "^5.9.6",
    "nanoid": "^5.0.9",
    "pino": "^9.6.0",
    "sharp": "^0.33.5",
    "socket.io": "^4.8.3",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.12",
    "@types/node": "^22.10.0",
    "drizzle-kit": "^0.30.1",
    "pino-pretty": "^13.0.0",
    "socket.io-client": "^4.8.3",
    "tsx": "^4.19.2",
    "vitest": "^2.1.8"
  }
}
