# ── Server ────────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3001
HOST=0.0.0.0

# ── Data / storage ──────────────────────────────────────────────────────────────
DB_PATH=./data/akpoker.sqlite
DATA_DIR=./data
AVATAR_DIR=./data/avatars

# ── CORS / origins (comma-separated) ───────────────────────────────────────────
ALLOWED_ORIGINS=http://localhost:5173

# ── Secrets (MUST be long & random in production) ──────────────────────────────
JWT_SECRET=dev-only-jwt-secret-change-me-please
COOKIE_SECRET=dev-only-cookie-secret-change-me!!

# ── Cookies (set COOKIE_SECURE=true behind HTTPS) ──────────────────────────────
COOKIE_SECURE=false
# COOKIE_DOMAIN=example.com

# ── Direct HTTPS (self-signed cert) — enables mic/getUserMedia without a proxy ──
# Generate: openssl req -x509 -newkey rsa:2048 -nodes -days 3650 \
#   -keyout certs/key.pem -out certs/cert.pem \
#   -subj "/CN=YOUR_IP" -addext "subjectAltName=IP:YOUR_IP"
# Then set COOKIE_SECURE=true and ALLOWED_ORIGINS=https://YOUR_IP:PORT
# HTTPS_KEY_PATH=certs/key.pem
# HTTPS_CERT_PATH=certs/cert.pem

# ── Voice / TURN (Phase 7) ─────────────────────────────────────────────────────
# TURN_HOST=turn.example.com
# TURN_STATIC_AUTH_SECRET=change-me-turn-secret
TURN_TTL_SECONDS=3600
STUN_URLS=stun:stun.l.google.com:19302

# ── SPA serving (single-origin deploy) ─────────────────────────────────────────
SERVE_WEB=false
WEB_DIST=../web/dist

# ── Deployment (docker-compose) ────────────────────────────────────────────────
# DOMAIN=poker.example.com           # Caddy issues a Let's Encrypt cert for this
# TURN_EXTERNAL_IP=203.0.113.10      # the VPS public IP, advertised by coturn
